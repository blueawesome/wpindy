---
const { item }: { item?: any } = Astro.props;
---

<article class="rounded-2xl overflow-hidden border border-black/10 bg-white/50 shadow-sm transition-transform duration-180 hover:-translate-y-1 hover:shadow-lg">
  <a href={`/work/${item.slug}/`} class="block">
    <div class="relative bg-neutral-100" style="aspect-ratio: 16 / 10;">
      <div class="absolute left-4 top-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red-400" aria-hidden></span>
        <span class="w-2 h-2 rounded-full bg-yellow-400" aria-hidden></span>
        <span class="w-2 h-2 rounded-full bg-green-400" aria-hidden></span>
      </div>
      <div class="absolute right-4 top-3 bg-white/20 text-xs text-neutral-800 px-2 py-0.5 rounded">{(item.stack && item.stack[0]) ?? ''}</div>
      {item.image ? <img loading="lazy" data-slug={item.slug} src={item.image} alt={item.title} class="h-full w-full object-cover" /> : (
        <div class="flex h-full items-center justify-center text-neutral-500">No image</div>
      )}
    </div>

    <div class="p-4">
      <p class="text-xs font-semibold uppercase text-neutral-600">{(item.workTypes && item.workTypes[0]) ?? item.clientVisibility ?? 'Client Withheld'}</p>
  <h3 class="mt-3 text-xl font-display text-neutral-900 leading-snug">{item.title}</h3>
      <p class="mt-2 text-sm text-neutral-700">{item.summary}</p>
    </div>

    <div class="px-4 pb-4">
      {item.workTypes?.length ? (
        <ul class="mt-2 flex flex-wrap gap-2 text-xs">
          {(item.workTypes || []).map((t: string) => (
            <li class="rounded-full bg-white/6 px-2 py-1 text-neutral-700 border border-black/10">{t}</li>
          ))}
        </ul>
      ) : null}

      <div class="mt-3 text-sm">
        <span class="text-wp-blue font-semibold">View Case Study →</span>
      </div>
    </div>
  </a>
</article>

<script>
  // optional tiny client-side hook: listen for clicks to add simple analytics event
  (function () {
    if (typeof window === 'undefined') return;
    document.addEventListener('click', function (e) {
      var target = e.target;
      if (!(target instanceof Element)) return;
      var el = target.closest('[data-slug]');
      if (!el) return;
      try {
        // placeholder for analytics hook
        // console.log('work:click', el.getAttribute('data-slug'));
      } catch (err) {}
    });
  })();
</script>
