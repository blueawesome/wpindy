---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  turnstile?: boolean;
}

const {
  title = 'WP Indy',
  description = 'Senior WordPress development for custom plugins, API integrations, ecommerce logic, and technical rescue work.',
  turnstile = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    {turnstile && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
  </head>
  <body>
    <slot />
  </body>
</html>
