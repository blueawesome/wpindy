---
import Layout from '../layouts/Layout.astro';
import EditorialImageSlot from '../components/EditorialImageSlot.astro';
import StripeDivider from '../components/StripeDivider.astro';

const caseStudies = [
  {
    id: 'commerce7',
    eyebrow: 'Commerce7 / WordPress',
    title: 'Commerce7 + WordPress storefront integration',
    summary:
      'Reworked a winery storefront by integrating Commerce7 into a custom WordPress build with faster filtering, custom field support, and a more flexible product architecture.',
    detail:
      'A good example of going well beyond default embeds to create a smoother storefront experience and a more maintainable technical setup.',
    href: '/work/st-julian-commerce7-wordpress-build/',
    image: '/work/placeholder-st-julian.svg',
    imageAlt: 'Commerce7 and WordPress storefront case study screenshot',
    tags: ['Filtering UX', 'Custom plugin work', 'Product architecture'],
  },
  {
    id: 'ai-search',
    eyebrow: 'Custom plugin / AI',
    title: 'AI search integration with admin reporting',
    summary:
      'Built a custom WordPress plugin that connected a client’s proprietary AI search system to their website, then added admin reporting and export tools for internal visibility.',
    detail:
      'This is the kind of project that shows WordPress acting as a real application layer, not just a CMS for publishing pages.',
    href: '/work/ai-search-plugin-admin-reporting/',
    image: '/work/placeholder-ai-search.svg',
    imageAlt: 'AI search plugin admin reporting screenshot',
    tags: ['LLM integration', 'Admin tools', 'Reporting & export'],
  },
  {
    id: 'rebuilds',
    eyebrow: 'Rebuild / migration',
    title: 'Rebuilds, cleanup, and migration work',
    summary:
      'Helped modernize aging WordPress setups by rebuilding brittle functionality, cleaning up fragile code, and creating a stronger foundation for future development.',
    detail:
      'The kind of work where judgment, clean execution, and long-term maintainability matter more than flashy features.',
    href: '/work/service-business-custom-checkout-flow/',
    image: '/work/placeholder-service-business.svg',
    imageAlt: 'WordPress rebuild or migration case study screenshot',
    tags: ['Refactoring', 'Technical cleanup', 'Migration support'],
  },
];

---

<Layout
  title="WP Indy | Senior WordPress Development"
  description="Senior WordPress development, API integrations, and custom plugins for agencies and teams."
>


  <main class="relative z-0">
	
    <section class="shell pb-10 md:pt-18 md:pb-28">
      <div class="max-w-5xl">

        <div class="mt-6 flex items-start gap-5 md:gap-7">
          <div>
            <h1 class="font-display text-[2.8rem] leading-[1.02] tracking-[-0.02em] text-white sm:text-[3.6rem] md:text-[4rem] lg:text-[4.2rem]">
              WordPress development,  <br />
			  API integrations, 
              &amp; custom plugins <br />
              <span class="hero-kicker-wrap">
                <span class="hero-kicker">for agencies and teams.</span>
              </span>
            </h1>

            <p class="mt-6 max-w-3xl text-lg leading-8 text-white/72 md:text-xl">
              15+ years of hands-on WordPress problem-solving, from custom functionality and technical architecture to complex integrations and advanced implementation.
            </p>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-5">
			<a href="/contact/" class="btn-pill btn-pill--white">Start a Project</a>
			<a href="/services/" class="text-base font-medium text-white/75 transition hover:text-white">
				View Services
			</a>
		</div>
		

     
      </div>
    </section><!--END Hero-->


  <StripeDivider />

	<section class="bg-[#e7dfd2] text-neutral-900">
		<div class="mx-auto max-w-7xl px-6 py-20 md:px-10 md:py-28">
			<div class="max-w-3xl">
			<p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-neutral-600">
				Flexible support for agencies and in-house teams
			</p>

            <h2 class="font-display text-4xl leading-tight tracking-tight md:text-5xl">
				A Senior WordPress developer who can lead complex work or strengthen the team you already have.
			</h2>

			<p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700">
				With 15+ years of hands-on WordPress experience across freelance and agency environments,
				I can step in as a technical lead, a white-label partner, or a focused senior developer for
				the parts of a project that need real depth.
			</p>
			</div>

			<div class="mt-14 grid gap-6 md:grid-cols-2">
			<div class="rounded-3xl border border-black/10 bg-white/60 p-7">
				<h3 class="text-xl font-semibold tracking-tight">Complex builds, not just assembly</h3>
				<p class="mt-3 leading-7 text-neutral-700">
				Custom plugins, integrations, subscriptions, debugging, refactoring, and backend problem-solving.
				</p>
			</div>

			<div class="rounded-3xl border border-black/10 bg-white/60 p-7">
				<h3 class="text-xl font-semibold tracking-tight">White-label when needed</h3>
				<p class="mt-3 leading-7 text-neutral-700">
				Comfortable supporting agencies and teams behind the scenes while fitting smoothly into existing workflows.
				</p>
			</div>

		

			<div class="rounded-3xl border border-black/10 bg-white/60 p-7">
				<h3 class="text-xl font-semibold tracking-tight">Fluent in agency and client work</h3>
				<p class="mt-3 leading-7 text-neutral-700">
				Used to balancing technical decisions, deadlines, communication, and real-world business constraints.
				</p>
			</div>

			<div class="rounded-3xl border border-black/10 bg-white/60 p-7">
				<h3 class="text-xl font-semibold tracking-tight">Rebuilds and migrations</h3>
				<p class="mt-3 leading-7 text-neutral-700">
				Whether you’re moving from another CMS, modernizing an aging site, or rebuilding a brittle setup in WordPress, I can help plan and execute the technical side cleanly.
				</p>
			</div>

			</div>
		</div>

      <!-- optional editorial slot near services -->
      <div class="mt-8">
        <EditorialImageSlot label="Future editorial image" variant="card" />
      </div>
		</section>


	<!--END Beige Section-->

	<div class="w-full">
    <div class="h-1 w-full bg-wp-gold"></div>
	</div>


<section class="bg-white text-neutral-900">
  <div class="mx-auto max-w-7xl px-6 py-20 md:px-10 md:py-28">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-neutral-500">
        Selected case studies
      </p>
  <h2 class="font-display text-4xl leading-tight tracking-tight md:text-5xl">
        A few examples of the work I get brought in for.
      </h2>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700">
        From custom plugins and API integrations to rebuilds and storefront architecture,
        here are a few examples of the kind of WordPress work I help teams solve.
      </p>
    </div>

    <div
      class="case-studies mt-14 grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.2fr)] lg:items-start"
      data-case-studies
      data-initial-id={caseStudies[0].id}
    >
      <div class="space-y-4">
        {caseStudies.map((study, index) => (
          <button
            type="button"
            class={`case-study-trigger group w-full rounded-3xl border border-black/10 bg-neutral-50 p-6 text-left transition hover:border-black/20 hover:bg-neutral-100 ${
              index === 0 ? 'is-active' : ''
            }`}
            data-case-trigger
            data-case-id={study.id}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">
              {study.eyebrow}
            </p>
            <h3 class="mt-3 text-2xl font-semibold tracking-tight">
              {study.title}
            </h3>
            <p class="mt-3 text-base leading-7 text-neutral-700">
              {study.summary}
            </p>
          </button>
        ))}
      </div>

      <div class="lg:sticky lg:top-28">
  <article class="overflow-hidden rounded-4xl border border-black/10 bg-neutral-50 shadow-[0_18px_50px_rgba(0,0,0,0.06)]">
          <div class="border-b border-black/10 px-5 py-3">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-black/15"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-black/10"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-black/10"></span>
            </div>
          </div>

          <div class="relative aspect-16/10 overflow-hidden bg-neutral-200">
            {caseStudies.map((study, index) => (
              <img
                src={study.image}
                alt={study.imageAlt}
                class={`case-study-image absolute inset-0 h-full w-full object-cover transition-opacity duration-300 ${
                  index === 0 ? 'opacity-100' : 'pointer-events-none opacity-0'
                }`}
                data-case-image
                data-case-id={study.id}
              />
            ))}

            <div class="absolute inset-0 bg-linear-to-t from-black/10 via-transparent to-transparent"></div>
          </div>

          <div class="p-6 md:p-8">
            {caseStudies.map((study, index) => (
              <div
                class={`case-study-copy transition-opacity duration-300 ${
                  index === 0 ? 'block opacity-100' : 'hidden opacity-0'
                }`}
                data-case-copy
                data-case-id={study.id}
              >
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-neutral-500">
                  {study.eyebrow}
                </p>

                <h3 class="mt-3 text-2xl font-semibold tracking-tight md:text-3xl">
                  {study.title}
                </h3>

                <p class="mt-4 text-base leading-7 text-neutral-700">
                  {study.detail}
                </p>

                <ul class="mt-6 flex flex-wrap gap-2 text-sm text-neutral-600">
                  {study.tags.map((tag) => (
                    <li class="rounded-full border border-black/10 px-3 py-1">
                      {tag}
                    </li>
                  ))}
                </ul>

                <div class="mt-8">
                  <a
                    href={study.href}
                    class="inline-flex items-center rounded-full border border-black/10 px-5 py-3 text-sm font-semibold transition hover:-translate-y-px hover:border-black/20"
                  >
                    View Case Study
                  </a>
                </div>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
    <div class="mt-10">
      <EditorialImageSlot label="Future editorial image" variant="wide" />
    </div>
  </div>
</section>

<script>
  const sections = document.querySelectorAll('[data-case-studies]');

  sections.forEach((section) => {
    const triggers = section.querySelectorAll('[data-case-trigger]');
    const images = section.querySelectorAll('[data-case-image]');
    const copies = section.querySelectorAll('[data-case-copy]');

    let activeId = section.getAttribute('data-initial-id');

  const setActive = (id: string) => {
      if (!id || id === activeId) return;

      triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-case-id') === id;
        trigger.classList.toggle('is-active', isActive);
        trigger.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      images.forEach((image) => {
        const isActive = image.getAttribute('data-case-id') === id;
        image.classList.toggle('opacity-100', isActive);
        image.classList.toggle('opacity-0', !isActive);
        image.classList.toggle('pointer-events-none', !isActive);
      });

      copies.forEach((copy) => {
        const isActive = copy.getAttribute('data-case-id') === id;

        if (isActive) {
          copy.classList.remove('hidden');
          requestAnimationFrame(() => {
            copy.classList.remove('opacity-0');
            copy.classList.add('opacity-100');
          });
        } else {
          copy.classList.remove('opacity-100');
          copy.classList.add('opacity-0');

          setTimeout(() => {
            if (copy.getAttribute('data-case-id') !== id) {
              copy.classList.add('hidden');
            }
          }, 220);
        }
      });

      activeId = id;
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-case-id');
        if (!id) return;
        setActive(id);
      });
    });
  });
</script>

  </main>
</Layout>
