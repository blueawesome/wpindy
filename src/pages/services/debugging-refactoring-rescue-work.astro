---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Debugging, Refactoring & Rescue Work | WP Indy"
  description="Senior WordPress debugging, refactoring, and rescue work for fragile inherited builds, broken functionality, and codebases that need stabilization."
>
  <section class="bg-[#e7dfd2] text-neutral-900">
    <div class="shell py-20">
      <h1 class="font-display text-4xl">Debugging, refactoring &amp; rescue work</h1>
      <p class="mt-4 text-neutral-700">Stabilize fragile builds and clean up inherited codebases.</p>
    </div>
  </section>
</Layout>
