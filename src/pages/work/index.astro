---
import Layout from '../../layouts/Layout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { work as workItems } from '../../data/work';
---

<Layout
  title="Selected Work | WP Indy"
  description="Custom WordPress builds, plugins, integrations, and ecommerce systems from 15+ years of hands-on development."
>
  <div class="w-full">
    <div class="h-1 w-full bg-wp-blue"></div>
    <div class="h-1 w-full bg-wp-red"></div>
    <div class="h-1 w-full bg-wp-gold"></div>
  </div>

  <section class="bg-[#e7dfd2] text-neutral-900">
    <div class="shell py-20">
  <div id="work-root" data-work={JSON.stringify(workItems)} x-data="workFilter()" x-init="init()" class="space-y-4">
      <div>
        <h1 class="font-display text-4xl">Selected Work</h1>
  <p class="mt-3 text-lg leading-relaxed text-neutral-700 max-w-2xl">Custom WordPress builds, plugins, integrations, and ecommerce systems from 15+ years of hands-on development.</p>
      </div>

      <!-- Filters -->
      <div class="filter-bar relative">
        <div class="mb-1 text-xs text-neutral-700">Filter by:</div>
  <div class="flex flex-wrap items-center gap-2 py-0.5" role="group" aria-label="Work filters">
          <button
            type="button"
            class="filter-pill"
            :class="selectedTypes.length === 0 ? 'is-active' : ''"
            @click.prevent="reset()"
            aria-label="Show all work"
          >All</button>
          <template x-for="t in preferredWorkTypes" :key="t">
            <button
              type="button"
              class="filter-pill"
              x-text="t"
              :class="selectedTypes.includes(t) ? 'is-active' : ''"
              :aria-pressed="selectedTypes.includes(t) ? 'true' : 'false'"
              @click.prevent="toggleType(t)"
            ></button>
          </template>
        </div>

  <div class="mt-2 mb-1 text-xs text-neutral-700">Stack:</div>
  <div class="flex flex-wrap items-center gap-2 py-0.5" role="group" aria-label="Stack filters">
          <template x-for="s in preferredStacks" :key="s">
            <button
              type="button"
              class="filter-pill"
              x-text="s"
              :class="selectedStacks.includes(s) ? 'is-active' : ''"
              :aria-pressed="selectedStacks.includes(s) ? 'true' : 'false'"
              @click.prevent="toggleStack(s)"
            ></button>
          </template>
        </div>
      </div>

      <!-- Grid -->
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {workItems.map((item) => (
          <div
            x-show={`matchesFilters('${item.slug}')`}
            class="work-card-transition"
            x-cloak
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform scale-95"
            x-transition:enter-end="opacity-100 transform scale-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 transform scale-100"
            x-transition:leave-end="opacity-0 transform scale-95"
          >
            <WorkCard item={item} />
          </div>
        ))}
      </div>

      <div class="mt-6">
        <p class="quiet-note text-xs text-neutral-600 max-w-3xl">Note: Some projects are anonymized or described without a public URL because they were completed as white-label agency work, involved private systems, or supported a larger client build.</p>
      </div>
    </div>
  </section>

  <script defer src="/js/work-filter.js"></script>
</Layout>
